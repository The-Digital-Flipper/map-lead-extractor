modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
# Build the prerendered site (BASE_PATH/PORT satisfy vite.config at build time)
# and the API server; then the API server serves both /api and the site.
build = ["sh", "-c", "BASE_PATH=/ PORT=5000 pnpm run build && pnpm --filter @workspace/db run push-force"]
run = ["sh", "-c", "node artifacts/api-server/dist/index.mjs"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["codex"]

[userenv]

[userenv.shared]
VITE_ADMIN_EMAIL = "gulfcoastcashforcars@gmail.com"
ADMIN_SECRET = "Kanaan12!"
# Real Twilio Account SID (AC...). TWILIO_ACCOUNT_SID in Secrets holds an API
# Key (SK...) by mistake; the app uses this AC SID + the account Auth Token
# (TWILIO_AUTH_TOKEN) for standard auth. Not sensitive — appears in API URLs.
TWILIO_ACCOUNT_SID_AC = "AC8dcc703ff000ad04c2750a748ea762ea"
