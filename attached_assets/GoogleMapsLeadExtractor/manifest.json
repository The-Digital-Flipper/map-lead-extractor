{
  "manifest_version": 3,
  "name": "Google Maps Lead Extractor",
  "short_name": "GMaps Lead Extractor",
  "description": "Extract visible Google Maps business listings and export CSV or XLSX.",
  "version": "1.2.3",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_title": "Google Maps Lead Extractor",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png",
      "256": "icons/icon-256.png",
      "512": "icons/icon-512.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png",
    "512": "icons/icon-512.png"
  },
  "background": {
    "service_worker": "src/service-worker.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps*",
        "https://www.google.co.uk/maps*",
        "https://www.google.ca/maps*",
        "https://www.google.com.au/maps*",
        "https://www.google.de/maps*",
        "https://www.google.fr/maps*",
        "https://www.google.es/maps*",
        "https://www.google.it/maps*",
        "https://www.google.co.in/maps*",
        "https://www.google.com.br/maps*",
        "https://www.google.com.mx/maps*",
        "https://www.google.nl/maps/*"
      ],
      "js": [
        "src/content-script.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.google.com/maps*",
        "https://www.google.co.uk/maps*",
        "https://www.google.ca/maps*",
        "https://www.google.com.au/maps*",
        "https://www.google.de/maps*",
        "https://www.google.fr/maps*",
        "https://www.google.es/maps*",
        "https://www.google.it/maps*",
        "https://www.google.co.in/maps*",
        "https://www.google.com.br/maps*",
        "https://www.google.com.mx/maps*",
        "https://www.google.nl/maps*"
      ],
      "js": [
        "src/net-intercept.js"
      ],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.google.com/*",
        "https://www.google.co.uk/*",
        "https://www.google.ca/*",
        "https://www.google.com.au/*",
        "https://www.google.de/*",
        "https://www.google.fr/*",
        "https://www.google.es/*",
        "https://www.google.it/*",
        "https://www.google.co.in/*",
        "https://www.google.com.br/*",
        "https://www.google.com.mx/*",
        "https://www.google.nl/*"
      ],
      "resources": [
        "panel/panel.html",
        "panel/panel.css",
        "panel/panel.js",
        "panel/export.js",
        "panel/enrichment.js",
        "panel/donate-qr.jpg",
        "panel/donate-cashapp.jpg",
        "src/messages.js",
        "src/selectors.js",
        "src/version.js"
      ]
    }
  ]
}